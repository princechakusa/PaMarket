{
  "id": "com.pamarket.app",
  "name": "PaMarket Zimbabwe",
  "short_name": "PaMarket",
  "description": "Zimbabwe's free marketplace — buy, sell, rent, find jobs and hire across all provinces. Post ads for free, message sellers instantly, and get verified.",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#1A3A8F",
  "theme_color": "#1A3A8F",
  "lang": "en",
  "dir": "ltr",
  "categories": ["shopping", "lifestyle", "business"],
  "prefer_related_applications": false,
  "icons": [
    { "src": "img/icon-192.png?v=5", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "img/icon-192.png?v=5", "sizes": "192x192", "type": "image/png", "purpose": "maskable" },
    { "src": "img/icon-512.png?v=5", "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "img/icon-512.png?v=5", "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
  ],
  "screenshots": [
    {
      "src": "img/screenshot-home.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Home screen — browse listings across Zimbabwe"
    },
    {
      "src": "img/screenshot-browse.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Browse categories — Electronics, Jobs, Rentals and more"
    },
    {
      "src": "img/screenshot-post.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Post a free listing in under 2 minutes"
    },
    {
      "src": "img/screenshot-messages.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Message sellers and buyers in real time"
    }
  ],
  "shortcuts": [
    {
      "name": "Post an Ad",
      "short_name": "Post",
      "description": "Post a new listing for free",
      "url": "./?action=post",
      "icons": [{ "src": "img/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Browse Listings",
      "short_name": "Browse",
      "description": "Browse all listings",
      "url": "./?action=browse",
      "icons": [{ "src": "img/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Messages",
      "short_name": "Messages",
      "description": "View your messages",
      "url": "./?tab=messages",
      "icons": [{ "src": "img/icon-192.png", "sizes": "192x192" }]
    }
  ],
  "share_target": {
    "action": "./",
    "method": "GET",
    "params": {
      "title": "share_title",
      "text": "share_text",
      "url": "share_url"
    }
  }
}
